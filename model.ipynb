import os
import warnings

# Hide Roboflow dependency warnings
os.environ["QWEN_2_5_ENABLED"] = "False"
os.environ["CORE_MODEL_SAM_ENABLED"] = "False"
os.environ["CORE_MODEL_SAM2_ENABLED"] = "False"
os.environ["CORE_MODEL_GAZE_ENABLED"] = "False"

# Hide macOS / Library warnings
warnings.filterwarnings("ignore")

import os
import cv2
import time
import firebase_admin
from firebase_admin import credentials, firestore
from inference import InferencePipeline

# --- 1. SUPPRESS SYSTEM WARNINGS ---
os.environ["QWEN_2_5_ENABLED"] = "False"
os.environ["CORE_MODEL_SAM_ENABLED"] = "False"
os.environ["CORE_MODEL_SAM2_ENABLED"] = "False"
os.environ["CORE_MODEL_GAZE_ENABLED"] = "False"

# --- 2. FIREBASE INITIALIZATION ---
if not firebase_admin._apps:
    cred = credentials.Certificate("serviceAccountKey.json")
    firebase_admin.initialize_app(cred)

db = firestore.client()

# --- 3. OPTIMIZED INFERENCE SINK WITH SECTOR MAPPING ---
last_upload_time = 0

def fod_sync_sink(predictions, video_frame):
    global last_upload_time
    current_time = time.time()
    
    # 1. PERFORMANCE: Resize for display only (keeps processing fast)
    display_frame = cv2.resize(video_frame.image, (640, 480))
    
    # Get original image width to calculate sectors accurately
    # Roboflow 'x' coordinates are relative to the original image size
    img_width = video_frame.image.shape[1]
    
    # 2. ACCURACY: High confidence filter
    detections = [p for p in predictions["predictions"] 
                  if p['class'] == "FOD" and p['confidence'] > 0.65]

    # 3. SECTOR LOGIC & THROTTLING
    if detections and (current_time - last_upload_time > 2):
        for pred in detections:
            # Calculate Sector based on the X center point of the box
            x_center = pred['x']
            
            if x_center < (img_width / 3):
                sector_name = "Sector A"
            elif x_center < (2 * img_width / 3):
                sector_name = "Sector B"
            else:
                sector_name = "Sector C"

            # Upload to Firebase
             db.collection("fod_alerts").add({
                "type": "FOD",
                "sector": sector_name,
                "confidence": float(pred['confidence']),
                "timestamp": firestore.SERVER_TIMESTAMP
            })
            print(f"📡 {sector_name} Alert Synced to Firebase")
        
        last_upload_time = current_time

    # Visual Feedback: Draw sectors on the screen for the operator
    # Draw vertical divider lines
    cv2.line(display_frame, (213, 0), (213, 480), (255, 255, 255), 1)
    cv2.line(display_frame, (426, 0), (426, 480), (255, 255, 255), 1)

    cv2.imshow("FOD Command Center - Live Feed", display_frame)
    
    if cv2.waitKey(1) & 0xFF == ord('q'):
        os._exit(0)

# --- 4. RUN THE PIPELINE ---
MY_API_KEY = "uArQmW8LPw2yqYtPI1et" 
MY_MODEL_ID = "fod-runway-dataset-a9r6k/1"

pipeline = InferencePipeline.init(
    model_id=MY_MODEL_ID,
    video_reference=0, # Use 0 for webcam or "video.mp4" for file
    on_prediction=fod_sync_sink, 
    api_key=MY_API_KEY
)

print("Starting FOD Detection Pipeline...")

try:
    pipeline.start()
    pipeline.join()
except KeyboardInterrupt:
    print("Stopping pipeline...")
finally:
    cv2.destroyAllWindows()q
